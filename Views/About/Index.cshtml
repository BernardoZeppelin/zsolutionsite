@model KitchenEquip.ViewModels.AboutViewModel
@{
    ViewData["Title"] = "Sobre Nós";
    var c = Model.Contact;
    Layout = "_Layout";
}
<link rel="stylesheet" href="~/site.css">

<section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="container">
        <div class="page-hero-content">
            <div class="hero-badge"><i class="bi bi-building me-1"></i> Nossa História</div>
            <h1 class="page-hero-title">Sobre a <span class="hero-title-accent">Z Solutions</span></h1>
            <p class="page-hero-sub">
                A força da tecnologia italiana impulsionando os resultados das cozinhas profissionais de todo o Brasil.
            </p>
        </div>
    </div>
</section>

<section class="about-story-section">
    <div class="container">
        <div class="story-grid">
            <div class="story-text-col">
                <h2 class="section-title">Nossa trajetória</h2>
                <p>
                    A <strong>Z Solutions</strong> foi criada com o objetivo de levar inovação, qualidade e tecnologia ao
                    mercado de equipamentos para cozinhas profissionais. Importamos diretamente da Europa, com foco
                    absoluto na excelência italiana.
                </p>
                <p>
                    Temos o orgulho de ser a <strong>importadora exclusiva da Arris no Brasil</strong>.
                    Nossa curadoria traz equipamentos reconhecidos mundialmente, oferecendo soluções que
                    aumentam exponencialmente o desempenho de restaurantes, hotéis e empresas do setor foodservice.
                </p>
                <p>
                    Sabemos que uma cozinha profissional não pode parar. Por isso, nosso atendimento é consultivo:
                    nós ajudamos você a escolher a melhor solução sob medida para o seu negócio, garantindo equipamentos
                    que priorizam performance, eficiência energética e durabilidade extrema.
                </p>
                <p>
                    Nosso compromisso vai muito além da venda. Acompanhamos cada cliente oferecendo uma
                    importação ágil e segura, além de suporte técnico especializado e assistência pós-venda
                    de alto nível.
                </p>
            </div>

            <div class="story-numbers-col">
                <div class="story-number-card">
                    <div class="sn-icon"><i class="bi bi-star-fill"></i></div>
                    <div class="sn-num" style="font-size: 1.5rem;">Exclusiva</div>
                    <div class="sn-label">Importadora Arris no Brasil</div>
                </div>
                <div class="story-number-card">
                    <div class="sn-icon"><i class="bi bi-globe-americas"></i></div>
                    <div class="sn-num">100%</div>
                    <div class="sn-label">Tecnologia Italiana</div>
                </div>
                <div class="story-number-card">
                    <div class="sn-icon"><i class="bi bi-tools"></i></div>
                    <div class="sn-num">Total</div>
                    <div class="sn-label">Suporte Especializado</div>
                </div>
                <div class="story-number-card">
                    <div class="sn-icon"><i class="bi bi-airplane-engines"></i></div>
                    <div class="sn-num">Ágil</div>
                    <div class="sn-label">Logística e Importação</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mvv-section">
    <div class="container">
        <div class="mvv-grid">
            <div class="mvv-card">
                <div class="mvv-icon"><i class="bi bi-crosshair2"></i></div>
                <h3>Missão</h3>
                <p>Fornecer equipamentos de alto nível, combinando inovação, desempenho e confiabilidade, oferecendo soluções completas para impulsionar o foodservice brasileiro.</p>
            </div>
            <div class="mvv-card mvv-card--accent">
                <div class="mvv-icon"><i class="bi bi-eye-fill"></i></div>
                <h3>Visão</h3>
                <p>Ser a maior referência no Brasil em equipamentos de alta performance para cozinhas profissionais, reconhecida pela excelência da tecnologia italiana.</p>
            </div>
            <div class="mvv-card">
                <div class="mvv-icon"><i class="bi bi-gem"></i></div>
                <h3>Valores</h3>
                <p>Atendimento consultivo, suporte técnico de excelência, transparência nas relações, agilidade na importação e compromisso absoluto com o cliente.</p>
            </div>
        </div>
    </div>
</section>

<section class="contact-section" id="ouvidoria">
    <div class="container">
        <div class="contact-header">
            <div class="hero-badge"><i class="bi bi-megaphone-fill me-1"></i> Ouvidoria & Atendimento</div>
            <h2 class="section-title">Fale conosco</h2>
            <p class="contact-intro">
                Dúvidas, cotações, suporte técnico ou ouvidoria — nosso canal de atendimento está disponível
                para você. Respondemos em até <strong>24 horas úteis</strong>.
            </p>
        </div>

        <div class="contact-grid">
            <div class="contact-cards-col">
                <div class="contact-card">
                    <div class="cc-icon cc-icon--blue"><i class="bi bi-envelope-fill"></i></div>
                    <div class="cc-body">
                        <h5>E-mail</h5>
                        <p>Para cotações, suporte e ouvidoria geral</p>
                        <a href="mailto:@c.Email" class="cc-link">@c.Email</a>
                    </div>
                </div>

                <div class="contact-card">
                    <div class="cc-icon cc-icon--dark"><i class="bi bi-telephone-fill"></i></div>
                    <div class="cc-body">
                        <h5>Telefones</h5>
                        <p>Atendimento comercial e suporte técnico</p>
                        <a href="tel:@c.Phone.Replace(" ", "").Replace("-", "").Replace("(", "").Replace(")", "")" class="cc-link d-block mb-1">BR: @c.Phone</a>
                        <a href="tel:393920646489" class="cc-link d-block">IT: (39) 39206-46489</a>
                    </div>
                </div>

                <div class="contact-card">
                    <div class="cc-icon cc-icon--green"><i class="bi bi-whatsapp"></i></div>
                    <div class="cc-body">
                        <h5>WhatsApp</h5>
                        <p>Atendimento rápido via mensagem</p>
                        <a href="https://wa.me/55@(c.WhatsApp.Replace(" ", "").Replace("-", "").Replace("(", "").Replace(")", ""))"
                           target="_blank" class="cc-link">@c.WhatsApp</a>
                    </div>
                </div>

                <div class="contact-card">
                    <div class="cc-icon cc-icon--orange"><i class="bi bi-geo-alt-fill"></i></div>
                    <div class="cc-body">
                        <h5>Endereço</h5>
                        <p>Visita técnica e retirada no local</p>
                        <span class="cc-link">@c.Address</span>
                    </div>
                </div>

                <div class="contact-card contact-card--hours">
                    <div class="cc-icon cc-icon--blue"><i class="bi bi-clock-fill"></i></div>
                    <div class="cc-body">
                        <h5>Horário de Atendimento</h5>
                        <span class="cc-link">Segunda a Sexta: 08h às 18h</span>
                    </div>
                </div>
            </div>

            <div class="ouvidoria-form-col">
                <div class="ouvidoria-form-card">
                    <div class="ouvidoria-form-title">
                        <i class="bi bi-chat-square-text-fill me-2"></i>Enviar mensagem
                    </div>
                    <p class="ouvidoria-form-subtitle">Preencha o formulário e nossa equipe especializada entrará em contato.</p>
                    <form novalidate>
                        <div class="form-group-custom">
                            <label class="form-label-custom">Nome completo *</label>
                            <input type="text" class="form-input-custom" placeholder="Seu nome" required />
                        </div>
                        <div class="form-row-custom">
                            <div class="form-group-custom">
                                <label class="form-label-custom">E-mail *</label>
                                <input type="email" class="form-input-custom" placeholder="seu@email.com" required />
                            </div>
                            <div class="form-group-custom">
                                <label class="form-label-custom">Telefone</label>
                                <input type="tel" class="form-input-custom" placeholder="(19) 99999-9999" />
                            </div>
                        </div>
                        <div class="form-group-custom">
                            <label class="form-label-custom">Assunto *</label>
                            <select class="form-input-custom" required>
                                <option value="" disabled selected>Selecione o assunto</option>
                                <option>Solicitar orçamento Arris</option>
                                <option>Atendimento Consultivo</option>
                                <option>Suporte técnico</option>
                                <option>Ouvidoria / Outros</option>
                            </select>
                        </div>
                        <div class="form-group-custom">
                            <label class="form-label-custom">Mensagem *</label>
                            <textarea class="form-input-custom" rows="4" placeholder="Descreva sua mensagem..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary-custom w-100" style="justify-content: center;">
                            <i class="bi bi-send-fill me-2"></i>Enviar mensagem
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>