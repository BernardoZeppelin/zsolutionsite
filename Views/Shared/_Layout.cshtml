<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} | " : "")ZSolutions import</title>
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "Importadora especializada em equipamentos profissionais de cozinha: fornos, grelhadores e salamandras.")" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <header class="site-header">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/img/logo_zsolutions.png" alt="Z Solutions Equipment Import" class="navbar-logo" />
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Menu">
                    <i class="bi bi-list"></i>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">

                        <li class="nav-item d-flex align-items-center gap-2 me-lg-4 mb-3 mb-lg-0 mt-3 mt-lg-0">
                            <a href="https://www.instagram.com/zsolutionsimport/" class="header-social-link" title="Instagram"><i class="bi bi-instagram"></i></a>
                            <a href="https://www.tiktok.com/@@zsolutionsimport" class="header-social-link" title="TikTok"><i class="bi bi-tiktok"></i></a>
                            <a href="https://wa.me/5519991557476" target="_blank" class="header-social-link" title="WhatsApp"><i class="bi bi-whatsapp"></i></a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                               asp-controller="Home" asp-action="Index">
                                <i class="bi bi-grid-3x3-gap me-1"></i>Produtos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "About" ? "active" : "")"
                               asp-controller="About" asp-action="Index">
                                <i class="bi bi-building me-1"></i>Sobre Nós
                            </a>
                        </li>
                        <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                            <a class="btn btn-primary-custom" asp-controller="About" asp-action="Index">
                                <i class="bi bi-headset me-1"></i>Contato
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="py-2">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col footer-brand-col">
                    <a asp-controller="Home" asp-action="Index" class="footer-brand d-block mb-3">
                        <img src="~/img/logo_zsolutions.png" alt="Z Solutions Equipment Import" class="footer-logo" />
                    </a>
                    <p class="footer-tagline">
                        A força da tecnologia italiana impulsionando seus resultados.<br>
                        Importadora exclusiva <strong>Arris</strong> no Brasil.
                    </p>
                </div>

                <div class="footer-col">
                    <h6 class="footer-heading">Navegação</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index">Produtos</a></li>
                        <li><a asp-controller="About" asp-action="Index">Sobre Nós</a></li>
                        <li><a href="https://wa.me/5519991557476" target="_blank">Ouvidoria</a></li>
                    </ul>
                </div>

                <div class="footer-col">
                    <h6 class="footer-heading">Categorias</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index" asp-route-category="Fornos">Fornos Elétricos</a></li>
                        <li><a asp-controller="Home" asp-action="Index" asp-route-category="Grelhadores">Grelhadores</a></li>
                        <li><a asp-controller="Home" asp-action="Index" asp-route-category="Salamandras">Salamandras</a></li>
                    </ul>
                </div>

                <div class="footer-col">
                    <h6 class="footer-heading">Contato</h6>
                    <ul class="footer-links footer-contact">
                        <li><i class="bi bi-telephone"></i> 🇧🇷 (19) 99155-7476</li>
                        <li><i class="bi bi-telephone"></i> 🇮🇹 (39) 39206-46489</li>
                        <li><i class="bi bi-envelope"></i> zsolutionsimport@gmail.com</li>
                        <li><i class="bi bi-clock"></i> Seg–Sex: 08h às 18h</li>
                    </ul>
                </div>
            </div>

            <div class="footer-bottom">
                <span>&copy; @DateTime.Now.Year Z Solutions Importadora. Todos os direitos reservados.</span>
                <span>Desenvolvido por <strong>Bernardo Zeppelin</strong></span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>